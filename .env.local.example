# ─────────────────────────────────────────────
# EARNI — Environment Variables
# Copy this file to .env.local and fill in values
# NEVER commit .env.local to GitHub
# ─────────────────────────────────────────────

# Supabase — new project, SE Asia region
# Get from: supabase.com → project → settings → API
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Claude (Anthropic)
# Get from: console.anthropic.com → API keys
ANTHROPIC_API_KEY=sk-ant-...

# Stripe — NZD
# Get from: dashboard.stripe.com → developers → API keys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — create these in Stripe dashboard first
# Products → Add product → set NZD price → copy price ID
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_FAMILY=price_...

# Phase 2 — add when ready, leave blank for now
ELEVENLABS_API_KEY=
DEEPGRAM_API_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
